{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "databasePassword": {
        "value": "${DB_PASSWORD}"
      },
      "srcExists": {
        "value": "${SERVICE_SRC_RESOURCE_EXISTS=false}"
      },
      "srcDefinition": {
        "value": {
          "settings": [
            {
              "name": "SECRET_KEY",
              "value": "${SECRET_KEY}",
              "secret": true,
              "secretRef": "secret-key"
            },
            {
              "name": "OPENAI_API_KEY",
              "value": "${OPENAI_API_KEY}",
              "secret": true,
              "secretRef": "openai-api-key"
            },
            {
              "name": "DJANGO_SUPERUSER_USERNAME",
              "value": "${DJANGO_SUPERUSER_USERNAME=admin}"
            },
            {
              "name": "DJANGO_SUPERUSER_EMAIL",
              "value": "${DJANGO_SUPERUSER_EMAIL=admin@example.com}"
            },
            {
              "name": "DJANGO_SUPERUSER_PASSWORD",
              "value": "${DJANGO_SUPERUSER_PASSWORD}",
              "secret": true,
              "secretRef": "django-superuser-password"
            },
            {
              "name": "ALLOWED_HOSTS",
              "value": "${ALLOWED_HOSTS}"
            }
          ]
        }
      },
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      }
    }
}
