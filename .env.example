# =============================================================================
# Barodybroject Environment Configuration Template
# =============================================================================
# Copy this file to .env and customize for your environment
# 
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# Security Notes:
#   - Never commit .env to version control
#   - Use strong passwords in production
#   - Rotate credentials regularly
# =============================================================================

# =============================================================================
# Django Admin Credentials (Auto-created on first run)
# =============================================================================
# These credentials are used by the 'ensure_admin' management command
# to automatically create or update the Django superuser.
#
# IMPORTANT: 
#   - Default values are provided for development convenience
#   - ALWAYS change these for production deployments
#   - In production, use secrets management (GitHub Secrets, Azure Key Vault, etc.)

# Admin username (default: admin)
DJANGO_SUPERUSER_USERNAME=admin

# Admin email (default: admin@localhost.local)
DJANGO_SUPERUSER_EMAIL=admin@localhost.local

# Admin password (default: admin - CHANGE THIS!)
DJANGO_SUPERUSER_PASSWORD=admin

# Where to save generated credentials file (default: setup_data/admin_credentials.txt)
ADMIN_CREDENTIALS_FILE=setup_data/admin_credentials.txt

# =============================================================================
# Application Settings
# =============================================================================
# Enable debug mode (True for development, False for production)
DEBUG=True

# Secret key for Django (generate a new one for production)
# You can generate a new secret key with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# Allowed hosts (comma-separated, * for development)
ALLOWED_HOSTS=localhost,127.0.0.1,*

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL database settings
DB_HOST=localhost
DB_NAME=barodydb
DB_USERNAME=postgres
DB_PASSWORD=postgres
POSTGRES_PORT=5432

# PostgreSQL container settings (for Docker)
POSTGRES_USER=postgres
POSTGRES_DB=barodydb
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_AUTH_METHOD=trust
POSTGRES_SSL=allow

# =============================================================================
# Docker Container Settings
# =============================================================================
# Service ports (customize to avoid conflicts)
DJANGO_DEV_PORT=8000
DJANGO_PROD_PORT=80
DOCS_PORT=8080
JEKYLL_PORT=4002

# =============================================================================
# Installation Wizard Configuration
# =============================================================================
# Skip installation check (true for development, false for production)
SKIP_INSTALLATION_CHECK=true

# Setup token expiry in hours (for headless installation)
SETUP_TOKEN_EXPIRY_HOURS=2

# Setup data directory
SETUP_DATA_DIR=./setup_data

# =============================================================================
# Azure Container App Settings
# =============================================================================
# Azure container app configuration
CONTAINER_APP_NAME=barodybroject
CONTAINER_APP_ENV_DNS_SUFFIX=localhost

# =============================================================================
# OpenAI Configuration
# =============================================================================
# OpenAI API key for AI features
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# Email Settings
# =============================================================================
# Email backend (console for development, SMTP for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP settings (for production)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password

# =============================================================================
# Jekyll Settings
# =============================================================================
# Jekyll environment (development or production)
JEKYLL_ENV=development

# =============================================================================
# E2E Testing (Playwright)
# =============================================================================
# Credentials for automated testing
E2E_USERNAME=e2e_user
E2E_EMAIL=e2e_user@example.com
E2E_PASSWORD=e2e_password_secret

# =============================================================================
# Production Environment Settings
# =============================================================================
# Set to True when running in production
RUNNING_IN_PRODUCTION=False

# Django settings module
DJANGO_SETTINGS_MODULE=barodybroject.settings.development

# Python configuration
PYTHONPATH=/workspace/src
PYTHONUNBUFFERED=1
